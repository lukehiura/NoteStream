#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-push checks..."

scripts/check-secrets.sh

# Optional outer cap so a wedged SwiftPM / test run cannot block push forever.
# macOS: brew install coreutils (gtimeout). Linux: timeout(1).
pre_push_timeout_sec="${NOTESTREAM_PRE_PUSH_TEST_TIMEOUT_SEC:-180}"
if command -v gtimeout >/dev/null 2>&1; then
  gtimeout "${pre_push_timeout_sec}s" make test-fast
elif command -v timeout >/dev/null 2>&1; then
  timeout "${pre_push_timeout_sec}s" make test-fast
else
  make test-fast
fi

echo "Pre-push checks passed."
