#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit checks..."

staged_paths="$(git diff --cached --name-only --diff-filter=ACMR)"

forbidden="$(printf '%s\n' "$staged_paths" | grep -Ei '(\.(caf|wav|m4a|mp3|flac|aiff)$|(^|/)Sessions(/|$)|(^|/)sessions(/|$)|(^|/)diagnostics\.jsonl$|(^|/)app\.jsonl$)' || true)"
if [ -n "$forbidden" ]; then
  echo "Do not commit private/local recording artifacts:"
  echo "$forbidden"
  exit 1
fi

# NOTE: Split env var names to avoid the hook self-matching the pattern text.
# Only scan added lines so secret removals / refactors do not trip on deleted hunks.
staged_secret_pattern="(sk-[A-Za-z0-9_-]{20,}|OPENAI_""API_KEY=|ANTHROPIC_""API_KEY=|HF_""TOKEN=|HUGGINGFACE_""TOKEN=|HUGGING_""FACE_HUB_TOKEN=)"
added_staged_lines=""
while IFS= read -r line; do
  case "$line" in
    '+++'*) continue ;;
  esac
  if [[ "$line" == +* ]]; then
    line="${line:1}"
    added_staged_lines+="${line}"$'\n'
  fi
done < <(git diff --cached --unified=0)

if [ -n "$added_staged_lines" ] && printf '%s' "$added_staged_lines" | grep -Eiq "$staged_secret_pattern"; then
  echo "Possible secret found in staged changes."
  exit 1
fi

staged_swift_files="$(printf '%s\n' "$staged_paths" | grep -E '^(Sources|Tests)/.*\.swift$' || true)"
staged_md_files="$(printf '%s\n' "$staged_paths" | grep -E '\.md$' || true)"

if [ -n "$staged_swift_files" ]; then
  echo "Formatting staged Swift files..."
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    swift-format format --in-place "$f"
    git add "$f"
    swift-format lint --strict "$f"
  done <<< "$staged_swift_files"

  echo "Running SwiftLint..."
  swiftlint lint --strict Sources Tests
fi

if [ -n "$staged_md_files" ]; then
  echo "Running Markdown lint..."
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    markdownlint "$f"
  done <<< "$staged_md_files"
fi

echo "Pre-commit checks passed."

